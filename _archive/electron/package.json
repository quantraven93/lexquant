{
  "name": "ap-legal-tracker",
  "version": "1.0.0",
  "description": "Legal Case Tracker for Andhra Pradesh Courts - High Court, District Courts & Supreme Court",
  "main": "src/main/main.js",
  "scripts": {
    "start": "npx electron .",
    "dev": "NODE_ENV=development npx electron .",
    "build": "electron-builder --mac",
    "build:all": "electron-builder --mac --win --linux"
  },
  "author": "AP Legal Tracker",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.1.0",
    "node-schedule": "^2.1.1",
    "electron-log": "^5.1.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.aplegaltracker.app",
    "productName": "AP Legal Tracker",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "AP Legal Tracker",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ]
  }
}
